generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  login     String   @unique
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
}

// ── Pages ─────────────────────────────────────────────────────────────────────

model Page {
  id              String   @id @default(uuid())
  slug            String
  url             String   @unique
  category        String
  name            String
  status          String   @default("published")
  sortOrder       Int      @default(0)
  content         Json
  menuTitle       String   @default("")
  menuDescription String   @default("")
  cardTitle       String   @default("")
  cardDescription String   @default("")
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pages")
}

// ── Articles (lessons / cases / default) ─────────────────────────────────────

model Article {
  id              String   @id @default(uuid())
  slug            String   @unique
  type            String   @default("default")
  status          String   @default("published")
  title           String
  description     String   @default("")
  content         Json
  coverPath       String?
  expertSlug      String?
  publishedAt     String   @default("")
  tagIds          String[]
  pinned          Boolean  @default(false)
  pinnedOrder     Int      @default(0)
  featured        Boolean  @default(false)
  cardVariant     String   @default("default")
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("articles")
}

// ── Glossary ──────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id              String   @id @default(uuid())
  slug            String   @unique
  status          String   @default("published")
  title           String
  description     String   @default("")
  content         Json
  tagIds          String[]
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("glossary_terms")
}

// ── Media Tags ────────────────────────────────────────────────────────────────

model MediaTag {
  id        String   @id
  label     String
  disabled  Boolean  @default(false)
  system    Boolean  @default(false)
  cardColor String?
  seo       Json?
  createdAt DateTime @default(now())

  @@map("media_tags")
}

// ── Experts ───────────────────────────────────────────────────────────────────

model Expert {
  id        String   @id @default(uuid())
  slug      String   @unique
  content   Json
  photoPath String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("experts")
}

// ── Testimonials ──────────────────────────────────────────────────────────────

model Testimonial {
  id         String   @id @default(uuid())
  content    Json
  avatarPath String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

// ── CTAs & Forms ──────────────────────────────────────────────────────────────

model CtaEntity {
  id        String   @id @default(uuid())
  name      String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ctas")
}

model FormEntity {
  id        String   @id @default(uuid())
  name      String
  content   Json
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forms")
}

// ── System config (shared mutable settings: partnerships, product-categories, about-rocketmind) ─

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ── Redirects ─────────────────────────────────────────────────────────────────

model Redirect {
  id         String   @id @default(uuid())
  fromUrl    String   @unique
  toUrl      String
  statusCode Int      @default(301)
  kind       String   @default("manual") // "auto" | "manual"
  isActive   Boolean  @default(true)
  entityType String?  // "article" | "glossary" | "page"
  entityId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("redirects")
}

// ── Form submissions (lead capture) ─────────────────────────────────────────

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  formName  String   @default("")
  pageUrl   String?
  data      Json     // {name, phone, email, message, ...}
  ipAddress String?
  userAgent String?
  // Per-channel delivery status: null = disabled, "ok" | "skipped" | "error"
  bitrix24Status String?
  bitrix24Error  String?
  emailStatus    String?
  emailError     String?
  telegramStatus String?
  telegramError  String?
  createdAt DateTime @default(now())

  @@map("form_submissions")
  @@index([formId])
  @@index([createdAt])
}

// ── Assets (centralized file registry) ────────────────────────────────────────

model Asset {
  id           String        @id @default(uuid())
  filePath     String        @unique
  publicUrl    String
  mimeType     String
  sizeBytes    Int
  role         String
  originalName String        @default("")
  pageId       String?
  articleId    String?
  glossaryId   String?
  formId       String?
  page         Page?         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  article      Article?      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  glossaryTerm GlossaryTerm? @relation(fields: [glossaryId], references: [id], onDelete: Cascade)
  form         FormEntity?   @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@map("assets")
}
