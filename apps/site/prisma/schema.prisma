generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id                       String                   @id @default(uuid())
  firstName                String
  lastName                 String
  login                    String                   @unique
  password                 String
  role                     Role                     @default(EDITOR)
  status                   UserStatus               @default(ACTIVE)
  email                    String?                  @unique
  emailVerifiedAt          DateTime?
  secondaryEmail           String?                  @unique
  secondaryEmailVerifiedAt DateTime?
  tokenVersion             Int                      @default(0)
  lastLoginAt              DateTime?
  lastLoginIp              String?
  lastLoginUserAgent       String?
  createdById              String?
  createdBy                User?                    @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers             User[]                   @relation("CreatedUsers")
  permissions              UserPermission[]
  auditLogs                AuditLog[]               @relation("AuditActor")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([createdById])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum UserStatus {
  ACTIVE
  FROZEN
}

// ── Permissions tree ──────────────────────────────────────────────────────────
// Path: dot-separated tokens describing the granted node in the access tree.
// Examples: "pages", "products", "products.<categoryId>", "products.<categoryId>.<productId>".
// A user has access to a node when an ancestor path (or the path itself) is present.

model UserPermission {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  path        String
  accessLevel AccessLevel
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, path])
  @@index([userId])
  @@map("user_permissions")
}

enum AccessLevel {
  VIEW
  EDIT
}

// ── Audit log (security events only) ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Tokens ────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  email       String
  isSecondary Boolean   @default(false)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// ── Rate-limit attempts ───────────────────────────────────────────────────────

model LoginAttempt {
  id        String   @id @default(uuid())
  login     String?
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([login, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

// ── Pages ─────────────────────────────────────────────────────────────────────

model Page {
  id              String   @id @default(uuid())
  slug            String
  url             String   @unique
  category        String
  name            String
  status          String   @default("published")
  sortOrder       Int      @default(0)
  content         Json
  menuTitle       String   @default("")
  menuDescription String   @default("")
  cardTitle       String   @default("")
  cardDescription String   @default("")
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pages")
}

// ── Articles (lessons / cases / default) ─────────────────────────────────────

model Article {
  id              String   @id @default(uuid())
  slug            String   @unique
  type            String   @default("default")
  status          String   @default("published")
  title           String
  description     String   @default("")
  content         Json
  coverPath       String?
  expertSlug      String?
  publishedAt     String   @default("")
  tagIds          String[]
  pinned          Boolean  @default(false)
  pinnedOrder     Int      @default(0)
  featured        Boolean  @default(false)
  cardVariant     String   @default("default")
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("articles")
}

// ── Glossary ──────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id              String   @id @default(uuid())
  slug            String   @unique
  status          String   @default("published")
  title           String
  description     String   @default("")
  content         Json
  tagIds          String[]
  metaTitle       String   @default("")
  metaDescription String   @default("")
  assets          Asset[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("glossary_terms")
}

// ── Media Tags ────────────────────────────────────────────────────────────────

model MediaTag {
  id        String   @id
  label     String
  disabled  Boolean  @default(false)
  system    Boolean  @default(false)
  cardColor String?
  seo       Json?
  createdAt DateTime @default(now())

  @@map("media_tags")
}

// ── Experts ───────────────────────────────────────────────────────────────────

model Expert {
  id        String   @id @default(uuid())
  slug      String   @unique
  content   Json
  photoPath String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("experts")
}

// ── Testimonials ──────────────────────────────────────────────────────────────

model Testimonial {
  id         String   @id @default(uuid())
  content    Json
  avatarPath String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

// ── CTAs & Forms ──────────────────────────────────────────────────────────────

model CtaEntity {
  id        String   @id @default(uuid())
  name      String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ctas")
}

model FormEntity {
  id        String   @id @default(uuid())
  name      String
  content   Json
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forms")
}

// ── System config (shared mutable settings: partnerships, product-categories, about-rocketmind) ─

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ── Redirects ─────────────────────────────────────────────────────────────────

model Redirect {
  id         String   @id @default(uuid())
  fromUrl    String   @unique
  toUrl      String
  statusCode Int      @default(301)
  kind       String   @default("manual") // "auto" | "manual"
  isActive   Boolean  @default(true)
  entityType String? // "article" | "glossary" | "page"
  entityId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("redirects")
}

// ── Form submissions (lead capture) ─────────────────────────────────────────

model FormSubmission {
  id             String   @id @default(uuid())
  formId         String
  formName       String   @default("")
  pageUrl        String?
  data           Json // {name, phone, email, message, ...}
  ipAddress      String?
  userAgent      String?
  // Per-channel delivery status: null = disabled, "ok" | "skipped" | "error"
  bitrix24Status String?
  bitrix24Error  String?
  emailStatus    String?
  emailError     String?
  telegramStatus String?
  telegramError  String?
  createdAt      DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
  @@map("form_submissions")
}

// ── Preview drafts (черновики для предпросмотра до публикации) ────────────────

model PreviewDraft {
  id        String   @id
  type      String
  slug      String
  publicUrl String
  payload   Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  @@index([slug, type])
  @@index([expiresAt])
  @@map("preview_drafts")
}

// ── Assets (centralized file registry) ────────────────────────────────────────

model Asset {
  id           String        @id @default(uuid())
  filePath     String        @unique
  publicUrl    String
  mimeType     String
  sizeBytes    Int
  role         String
  originalName String        @default("")
  pageId       String?
  articleId    String?
  glossaryId   String?
  formId       String?
  page         Page?         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  article      Article?      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  glossaryTerm GlossaryTerm? @relation(fields: [glossaryId], references: [id], onDelete: Cascade)
  form         FormEntity?   @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@map("assets")
}

// ── Teacher: places, programs, agents, students ──────────────────────────────

model Place {
  id        String    @id @default(uuid())
  name      String
  address   String?
  programs  Program[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("places")
}

model Program {
  id                 String         @id @default(uuid())
  title              String
  placeId            String?
  place              Place?         @relation(fields: [placeId], references: [id])
  startsAt           DateTime
  endsAt             DateTime
  /// Свитч «программа активна». Когда false — участники видят модалку
  /// «программа завершена», чат становится read-only, новые сообщения
  /// закрыты плашкой «оформите подписку».
  isActive           Boolean        @default(true)
  joinToken          String?        @unique
  joinTokenRotatedAt DateTime?
  agents             ProgramAgent[]
  students           Student[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("programs")
}

model Mascot {
  id        String    @id @default(uuid())
  name      String
  pack      String?
  imagePath String
  isBuiltIn Boolean   @default(false)
  agents    AiAgent[]
  createdAt DateTime  @default(now())

  @@index([pack])
  @@map("mascots")
}

model AiAgent {
  id               String           @id @default(uuid())
  slug             String           @unique
  name             String
  role             String           @default("")
  valueDescription String           @default("")
  avatarMascotId   String?
  avatarMascot     Mascot?          @relation(fields: [avatarMascotId], references: [id])
  avatarPath       String?
  targets          String[]
  /// Порядковый номер — определяет порядок в списке агентов в админке и в
  /// сайдбаре saas-teacher. По возрастанию. 0 = верх.
  serial           Int              @default(0)
  n8nWebhookUrl    String
  n8nSecret        String?
  systemPrompt     String? // черновик системного промпта; пока read-only для бэка (промпты живут в n8n/OpenAI)
  notes            String?
  programs         ProgramAgent[]
  sessions         StudentSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([serial])
  @@map("ai_agents")
}

model ProgramAgent {
  programId      String
  agentId        String
  isAvailable    Boolean   @default(false)
  availableSince DateTime?
  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  agent          AiAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([programId, agentId])
  @@map("program_agents")
}

model Student {
  id        String           @id @default(uuid())
  email     String           @unique
  firstName String?
  lastName  String?
  role      String? // «Роль в бизнесе»
  industry  String? // «Сфера деятельности»
  region    String? // «Регион»
  isActive  Boolean          @default(true)
  programId String?
  program   Program?         @relation(fields: [programId], references: [id])
  joinedVia String?
  joinedAt  DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  projects  StudentProject[]
  sessions  StudentSession[]

  @@map("students")
}

model StudentProject {
  id        String            @id @default(uuid())
  studentId String
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name      String
  profile   Json?
  artifacts StudentArtifact[]
  sessions  StudentSession[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("student_projects")
}

model StudentSession {
  id            String           @id @default(uuid())
  studentId     String
  projectId     String
  agentId       String
  threadId      String?
  summary       String?
  lastMessageAt DateTime?
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  project       StudentProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent         AiAgent          @relation(fields: [agentId], references: [id])
  messages      StudentMessage[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([projectId, agentId])
  @@map("student_sessions")
}

model StudentMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   StudentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@map("student_messages")
}

model StudentArtifact {
  id        String         @id @default(uuid())
  projectId String
  agentId   String?
  kind      String
  title     String?
  content   Json
  project   StudentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([projectId])
  @@map("student_artifacts")
}

model OtpCode {
  id         String    @id @default(uuid())
  email      String
  codeHash   String
  programId  String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@map("otp_codes")
}
