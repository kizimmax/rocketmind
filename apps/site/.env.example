# ── База данных ────────────────────────────────────────────────────────────────
# Для локальной разработки: запусти PostgreSQL локально (например через Docker)
# docker run -d --name rm-pg -e POSTGRES_DB=rocketmind -e POSTGRES_USER=rocketmind \
#   -e POSTGRES_PASSWORD=rocketmind -p 5432:5432 postgres:16-alpine
DATABASE_URL=postgresql://rocketmind:rocketmind@localhost:5432/rocketmind

# ── JWT авторизация ────────────────────────────────────────────────────────────
# Любая случайная строка длиной 32+ символа
# Генерация: openssl rand -hex 32
JWT_SECRET=your-secret-here

# ── Хранилище файлов ───────────────────────────────────────────────────────────
# На сервере (Amvera): /data/uploads (persistent volume)
# Локально: можно оставить дефолт или указать абсолютный путь
UPLOADS_DIR=/data/uploads

# ── Firebase (только для apps/internal / R-Plan) ───────────────────────────────
# Передаются как build args в Docker, не нужны для site/saas
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
