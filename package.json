{
  "name": "rocketmind",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "ui:build": "npm run build --workspace=packages/ui",
    "ui:dev": "npm run dev --workspace=packages/ui",
    "dev:ds": "npm run dev --workspace=apps/design-system",
    "dev:site": "npm run dev --workspace=apps/site",
    "dev:saas": "npm run dev --workspace=apps/saas",
    "dev:internal": "npm run dev --workspace=apps/internal",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
